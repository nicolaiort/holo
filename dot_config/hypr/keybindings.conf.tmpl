#! Actions
##! Default actions
bind = $mainMod, Return, exec, $terminal
bind = $mainMod, Q, killactive,
bind = $mainMod, Space, exec, rofi -show drun -modi "drun,calc" -kb-mode-next "Tab" -kb-element-next "" -no-sort -no-history -calc-command "wl-copy '{result}'" # Open rofi
bind = $mainMod, L, exec, hyprlock
bind = $mainMod+Shift, V, exec, cliphist list | rofi -dmenu -display-columns 2 | cliphist decode | wl-copy
bind = $mainMod+Shift, C, exec, hyprpicker | wl-copy
bind = $mainMod, Period, exec, rofimoji --action "copy"

##! Session
bind = Super+Shift, E, exec, hyprctl dispatch exit
bind = $mainMod+Shift, R, exec, bash $HOME/.config/hypr/reload.sh
bind = Super, X, exec, echo -e "No\nYes" | rofi -dmenu -p "Shutdown?" -mesg "Are you sure you want to shut down?" | grep -q "^Yes$" && shutdown now

#! Windows

##! Workspaces
# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

##! Window management
# Focusing
bind = Super+Shift, Left, movefocus, l # [hidden]
bind = Super+Shift, Right, movefocus, r # [hidden]
bind = Super+Shift, Up, movefocus, u # [hidden]
bind = Super+Shift, Down, movefocus, d # [hidden]

# Arrangement
bind = Super, Left, movewindow, l # [hidden]
bind = Super, Right, movewindow, r # [hidden]
bind = Super, Up, movewindow, u # [hidden]
bind = Super, Down, movewindow, d # [hidden]
bind = $mainMod, V, togglefloating,

# Fullscreen
bind = Super, F, fullscreen, 0
bind = Super, D, fullscreen, 1

##! Mouse buttons
bind = , mouse:276, exec, wtype -M ctrl t -m ctrl  # Back button: close tab
bind = , mouse:275, exec, wtype -M ctrl w -m ctrl  # Forward button: open tab

{{ if eq .chezmoi.hostname "blackpanther" }}    
##! Dictation
bind = , F24, exec, voxtype record start
bindr = , F24, exec, voxtype record stop
bind = , Pause, exec, voxtype record start
bindr = , Pause, exec, voxtype record stop

# F23: push-to-talk → opencode (hold to speak, release to send prompt)
bind = , F23, exec, voxtype record start --profile opencode --no-auto-submit
bindr = , F23, exec, voxtype record stop
{{ end }}


##! Screenshots
bind =, Print, exec, grim -g "$(slurp)" - | wl-copy && wl-paste > ~/Pictures/screenshots/Screenshot-$(date +%F_%T).png | dunstify "Screenshot of the region taken" -t 1000 # screenshot of a region 
bind = SHIFT, Print, exec, grim - | wl-copy && wl-paste > ~/Pictures/screenshots/Screenshot-$(date +%F_%T).png | dunstify "Screenshot of whole screen taken" -t 1000 # screenshot of the whole screen

##! Custom scripts
bind = Super+Shift, T, exec, bash ~/.local/bin/devsetup restore